{
  "name": "app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^@noble/curves/(.*)$": "<rootDir>/node_modules/@noble/curves/$1.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@noble)"
    ]
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "expo": "~54.0.34",
    "expo-clipboard": "~8.0.8",
    "expo-crypto": "~15.0.9",
    "expo-status-bar": "~3.0.9",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "private": true
}
